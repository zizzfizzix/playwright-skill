{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "plugins/playwright-test": {
      "release-type": "simple",
      "component": "playwright-test",
      "tag-component": "playwright-test",
      "changelog-path": "plugins/playwright-test/CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "plugins/playwright-test/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='playwright-test')].version"
        }
      ]
    }
  }
}
