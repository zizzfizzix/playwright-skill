{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "plugins/playwright-scaffold": {
      "release-type": "simple",
      "component": "playwright-scaffold",
      "tag-component": "playwright-scaffold",
      "changelog-path": "plugins/playwright-scaffold/CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "plugins/playwright-scaffold/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='playwright-scaffold')].version"
        }
      ]
    },
    "plugins/playwright-spec": {
      "release-type": "simple",
      "component": "playwright-spec",
      "tag-component": "playwright-spec",
      "changelog-path": "plugins/playwright-spec/CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "plugins/playwright-spec/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='playwright-spec')].version"
        }
      ]
    }
  }
}
